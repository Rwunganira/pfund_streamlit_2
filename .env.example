# Copy this file to .env and fill in your actual values. Never commit .env.
DATABASE_URL=postgres://user:pass@host:5432/dbname
WAREHOUSE_URL=postgres://user:pass@host:5432/dbname

# JWT — must be identical in both Flask and Streamlit apps
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_long_random_string

# URLs
FLASK_AUTH_URL=https://your-flask-app.herokuapp.com   # Flask app base URL
STREAMLIT_URL=https://your-app.streamlit.app          # Streamlit app base URL

# Email (Gmail App Password)
# Setup: myaccount.google.com → Security → 2FA → App Passwords → Mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.gmail@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx
FROM_EMAIL=your.gmail@gmail.com
